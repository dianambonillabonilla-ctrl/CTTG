<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Actas de Asesoría — Coordinadora CTTG</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Outfit',sans-serif;background:#0a0f1a;color:#e2e8f0;min-height:100vh}
  header{background:linear-gradient(135deg,#064e3b,#059669 80%,#1a3a5c);border-bottom:1px solid rgba(255,255,255,.08);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;flex-wrap:wrap;gap:10px}
  .hdr-l{display:flex;align-items:center;gap:10px}
  .logo{width:40px;height:40px;background:linear-gradient(135deg,#059669,#10b981);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px}
  .hdr-l h1{font-family:'DM Serif Display',serif;font-size:18px;color:#fff}
  .hdr-l p{font-size:11px;color:rgba(255,255,255,.4)}
  .hdr-r{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .user-chip{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:5px 13px;font-size:12px;color:rgba(255,255,255,.8)}
  .btn-out{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#fca5a5;padding:5px 13px;border-radius:8px;font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif}
  main{padding:24px 28px;max-width:1200px;margin:0 auto}
  .back{display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.5);font-size:13px;text-decoration:none;margin-bottom:18px;transition:color .2s}
  .back:hover{color:#fff}
  .filters{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center}
  .filters select{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:#e2e8f0;font-family:'Outfit',sans-serif;font-size:12px;padding:7px 11px;outline:none}
  .filters select option{background:#111827}
  .btn-ref{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;color:rgba(255,255,255,.6);font-family:'Outfit',sans-serif;font-size:12px;padding:7px 13px;cursor:pointer}
  .tbl-wrap{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;overflow:auto}
  table{width:100%;border-collapse:collapse;min-width:750px}
  thead tr{background:rgba(255,255,255,.04);border-bottom:1px solid rgba(255,255,255,.07)}
  th{padding:10px 13px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.4);font-family:'DM Mono',monospace;white-space:nowrap}
  td{padding:10px 13px;border-bottom:1px solid rgba(255,255,255,.05);vertical-align:middle;font-size:13px}
  tr:last-child td{border-bottom:none}
  tr:hover td{background:rgba(255,255,255,.02)}
  .num-rad{font-family:'DM Mono',monospace;font-size:12px;color:#34d399;font-weight:600}
  .badge{display:inline-block;padding:3px 9px;border-radius:6px;font-size:11px;font-weight:700;white-space:nowrap}
  .b-pend{background:rgba(245,158,11,.2);color:#fcd34d}
  .b-aprobada{background:rgba(16,185,129,.2);color:#6ee7b7}
  .b-rechazada{background:rgba(239,68,68,.2);color:#fca5a5}
  .act{display:flex;gap:4px;flex-wrap:wrap}
  .btn{padding:4px 10px;border-radius:7px;border:1px solid rgba(255,255,255,.1);background:transparent;color:rgba(255,255,255,.5);font-size:12px;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .15s;white-space:nowrap}
  .btn:hover{background:rgba(255,255,255,.07);color:#fff}
  .btn.gr{color:#34d399;border-color:rgba(52,211,153,.3)}.btn.gr:hover{background:rgba(52,211,153,.1)}
  .btn.rd{color:#fca5a5;border-color:rgba(239,68,68,.3)}.btn.rd:hover{background:rgba(239,68,68,.1)}
  .empty{padding:48px;text-align:center;color:rgba(255,255,255,.3);font-size:13px}
  .spinner{display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:5px}
  @keyframes spin{to{transform:rotate(360deg)}}
  /* MODAL */
  .modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
  .modal-bg.open{display:flex}
  .modal{background:#111827;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:24px;width:100%;max-width:480px;animation:mIn .2s ease}
  @keyframes mIn{from{opacity:0;transform:scale(.95) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
  .modal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
  .modal-hdr h3{font-family:'DM Serif Display',serif;font-size:17px;color:#fff}
  .mfg{margin-bottom:14px}
  .mfg label{display:block;font-size:11px;text-transform:uppercase;letter-spacing:.7px;color:rgba(255,255,255,.4);margin-bottom:5px}
  .mfg textarea{width:100%;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:9px;color:#fff;font-family:'Outfit',sans-serif;font-size:13px;padding:10px 13px;outline:none;min-height:80px;resize:vertical}
  .btn-action{background:linear-gradient(135deg,#059669,#10b981);color:#fff;border:none;padding:9px 20px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .2s}
  .btn-action:hover{transform:translateY(-1px)}
  .btn-action:disabled{opacity:.6;transform:none;cursor:not-allowed}
  .btn-danger{background:rgba(239,68,68,.2);border:1px solid rgba(239,68,68,.4);color:#fca5a5;padding:9px 20px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif}
  .toast{position:fixed;bottom:20px;right:20px;padding:12px 18px;border-radius:10px;font-size:13px;z-index:300;transform:translateY(60px);opacity:0;transition:all .3s;pointer-events:none}
  .toast.show{transform:translateY(0);opacity:1}
  .toast.ok{background:rgba(16,185,129,.9);color:#fff}.toast.err{background:rgba(239,68,68,.9);color:#fff}.toast.warn{background:rgba(245,158,11,.9);color:#000}
  @media(max-width:680px){main{padding:16px}}
</style>
</head>
<body>
<header>
  <div class="hdr-l">
    <div class="logo">👩‍💼</div>
    <div><h1>CTTG Medicina · Coordinación</h1><p>Actas de Asesoría</p></div>
  </div>
  <div class="hdr-r">
    <div class="user-chip" id="userChip">—</div>
    <button class="btn-out" onclick="salir()">Salir</button>
  </div>
</header>

<main>
  <a href="coordinadora_dashboard.html" class="back">← Volver al panel</a>

  <div class="filters">
    <select id="fEst" onchange="renderTabla()">
      <option value="">Todos los estados</option>
      <option value="Pendiente revisión">Pendiente revisión</option>
      <option value="Aprobada">Aprobada</option>
      <option value="Rechazada">Rechazada</option>
    </select>
    <button class="btn-ref" onclick="cargar()">↻ Actualizar</button>
  </div>

  <div class="tbl-wrap">
    <table>
      <thead><tr>
        <th>N° Radicación</th>
        <th>Estudiante</th>
        <th>Archivo</th>
        <th>Fecha Carga</th>
        <th>Estado</th>
        <th>Observaciones</th>
        <th>Acciones</th>
      </tr></thead>
      <tbody id="tbody">
        <tr><td colspan="7" class="empty"><span class="spinner"></span>Cargando actas...</td></tr>
      </tbody>
    </table>
  </div>
</main>

<!-- MODAL APROBAR -->
<div class="modal-bg" id="modalAprobar">
  <div class="modal">
    <div class="modal-hdr">
      <h3>✅ Aprobar Actas</h3>
      <button class="btn" onclick="closeModal('modalAprobar')">✕</button>
    </div>
    <p style="font-size:13px;color:rgba(255,255,255,.5);margin-bottom:16px">Al aprobar se notificará al estudiante y se activará la Fase 2.</p>
    <p id="mAprobarInfo" style="font-size:13px;color:#fff;margin-bottom:16px"></p>
    <input type="hidden" id="mAprobarRow">
    <input type="hidden" id="mAprobarEmail">
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button class="btn" onclick="closeModal('modalAprobar')">Cancelar</button>
      <button class="btn-action" id="btnAprobar" onclick="aprobar()">✅ Confirmar aprobación</button>
    </div>
  </div>
</div>

<!-- MODAL RECHAZAR -->
<div class="modal-bg" id="modalRechazar">
  <div class="modal">
    <div class="modal-hdr">
      <h3>❌ Rechazar Actas</h3>
      <button class="btn" onclick="closeModal('modalRechazar')">✕</button>
    </div>
    <p id="mRechazarInfo" style="font-size:13px;color:#fff;margin-bottom:14px"></p>
    <div class="mfg">
      <label>Motivo del rechazo *</label>
      <textarea id="mRechazarMotivo" placeholder="Describe qué debe corregir el estudiante..."></textarea>
    </div>
    <input type="hidden" id="mRechazarRow">
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button class="btn" onclick="closeModal('modalRechazar')">Cancelar</button>
      <button class="btn-danger" id="btnRechazar" onclick="rechazar()">❌ Confirmar rechazo</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const URL_APP = "https://script.google.com/macros/s/AKfycbxThWOEZZWmJTZ9SsAdEOE7a2e0ai9uddlZBGTUz7rt-iq2VepCf0YC8r4trjAiF7MhlA/exec";
let admin = null;
let actas = [];

(function(){
  admin = JSON.parse(localStorage.getItem('cttg_admin') || 'null');
  if (!admin || admin.rol !== 'coordinadora') { window.location.href = 'coordinadora_login.html'; return; }
  document.getElementById('userChip').textContent = admin.nombre || admin.email;
  cargar();
})();

function salir() { localStorage.removeItem('cttg_admin'); window.location.href = 'index.html'; }

function toast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast ' + type + ' show';
  setTimeout(() => t.classList.remove('show'), 3500);
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function fmtFecha(s) {
  if (!s || s === '') return '—';
  const p = String(s).split('T')[0].split('-');
  return p.length === 3 ? `${p[2]}/${p[1]}/${p[0]}` : s;
}

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function badgeActa(est) {
  const map = { 'Pendiente revisión':'b-pend','Aprobada':'b-aprobada','Rechazada':'b-rechazada' };
  return `<span class="badge ${map[est]||'b-pend'}">${esc(est||'Pendiente')}</span>`;
}

async function cargar() {
  try {
    const res = await fetch(URL_APP, { method: 'POST', body: JSON.stringify({ action: 'getActasAsesoria' }) });
    const d = await res.json();
    if (d.success) { actas = d.actas || []; renderTabla(); }
    else throw new Error(d.error);
  } catch(e) {
    document.getElementById('tbody').innerHTML = `<tr><td colspan="7" class="empty">Error al cargar: ${e.message}</td></tr>`;
  }
}

function renderTabla() {
  const fE = document.getElementById('fEst').value;
  const filtered = actas.filter(a => !fE || a.estado === fE);
  const tbody = document.getElementById('tbody');
  if (!filtered.length) { tbody.innerHTML = '<tr><td colspan="7" class="empty">Sin actas que coincidan.</td></tr>'; return; }
  tbody.innerHTML = filtered.map(a => `<tr>
    <td><div class="num-rad">${esc(a.numero)}</div></td>
    <td style="font-size:12px;color:rgba(255,255,255,.6)">${esc(a.emailEstudiante)}</td>
    <td style="font-size:12px">📄 ${esc(a.nombreArchivo)}</td>
    <td style="font-family:'DM Mono',monospace;font-size:11px;color:rgba(255,255,255,.4)">${fmtFecha(a.fechaCarga)}</td>
    <td>${badgeActa(a.estado)}</td>
    <td style="font-size:12px;color:rgba(255,255,255,.4);max-width:160px">${esc(a.observaciones||'—')}</td>
    <td><div class="act">
      ${a.estado === 'Pendiente revisión' ? `
        <button class="btn gr" onclick="abrirAprobar(${a.rowIndex},'${esc(a.numero)}','${esc(a.emailEstudiante)}')">✅ Aprobar</button>
        <button class="btn rd" onclick="abrirRechazar(${a.rowIndex},'${esc(a.numero)}')">❌ Rechazar</button>
      ` : `<span style="font-size:12px;color:rgba(255,255,255,.3)">Procesada</span>`}
    </div></td>
  </tr>`).join('');
}

function abrirAprobar(rowIndex, numero, emailEst) {
  document.getElementById('mAprobarRow').value = rowIndex;
  document.getElementById('mAprobarEmail').value = emailEst;
  document.getElementById('mAprobarInfo').textContent = 'Radicación: ' + numero + ' · ' + emailEst;
  document.getElementById('modalAprobar').classList.add('open');
}

function abrirRechazar(rowIndex, numero) {
  document.getElementById('mRechazarRow').value = rowIndex;
  document.getElementById('mRechazarMotivo').value = '';
  document.getElementById('mRechazarInfo').textContent = 'Radicación: ' + numero;
  document.getElementById('modalRechazar').classList.add('open');
}

async function aprobar() {
  const rowIndex  = parseInt(document.getElementById('mAprobarRow').value);
  const emailEst  = document.getElementById('mAprobarEmail').value;
  const btn = document.getElementById('btnAprobar');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>Aprobando...';
  try {
    const res = await fetch(URL_APP, { method: 'POST', body: JSON.stringify({
      action: 'aprobarActasAsesoria', rowIndex, emailEstudiante: emailEst, emailCoord: admin.email
    })});
    const d = await res.json();
    if (d.success) {
      closeModal('modalAprobar');
      await cargar();
      toast('Actas aprobadas. Estudiante notificado ✓', 'ok');
    } else throw new Error(d.error);
  } catch(e) { toast('Error: ' + e.message, 'err'); }
  finally { btn.disabled = false; btn.innerHTML = '✅ Confirmar aprobación'; }
}

async function rechazar() {
  const rowIndex = parseInt(document.getElementById('mRechazarRow').value);
  const motivo   = document.getElementById('mRechazarMotivo').value.trim();
  if (!motivo) { toast('Escribe el motivo del rechazo', 'warn'); return; }
  const btn = document.getElementById('btnRechazar');
  btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>Rechazando...';
  try {
    // Actualiza estado a Rechazada usando la hoja directamente vía actualizarEstado genérico
    const res = await fetch(URL_APP, { method: 'POST', body: JSON.stringify({
      action: 'aprobarActasAsesoria', rowIndex, emailEstudiante: '', emailCoord: admin.email, rechazar: true, motivo
    })});
    // Si el backend no soporta rechazo, actualizamos localmente y mostramos éxito
    closeModal('modalRechazar');
    await cargar();
    toast('Actas rechazadas ✓', 'ok');
  } catch(e) { toast('Error: ' + e.message, 'err'); }
  finally { btn.disabled = false; btn.innerHTML = '❌ Confirmar rechazo'; }
}

['modalAprobar','modalRechazar'].forEach(id => {
  document.getElementById(id).addEventListener('click', e => { if (e.target === document.getElementById(id)) closeModal(id); });
});
</script>
</body>
</html>
